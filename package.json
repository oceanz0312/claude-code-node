{
  "name": "claude-code-node",
  "version": "0.0.1",
  "description": "TypeScript SDK for Claude Code CLI",
  "keywords": [
    "claude-code",
    "claude",
    "agent-sdk",
    "cli-wrapper",
    "anthropic",
    "typescript",
    "streaming",
    "session-management"
  ],
  "author": "",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run clean && bun run build:esm && bun run build:cjs && bun run build:types && bun run build:cjs-dts && bun run build:obfuscate",
    "build:esm": "bun build ./src/index.ts --outdir ./dist --target node --format esm --packages external --minify",
    "build:cjs": "bun build ./src/index.ts --outfile ./dist/index.cjs --target node --format cjs --packages external --minify",
    "build:obfuscate": "terser dist/index.js --compress --mangle toplevel --module -o dist/index.js && terser dist/index.cjs --compress --mangle toplevel -o dist/index.cjs",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "build:cjs-dts": "printf 'export * from \"./index.js\";\\n' > dist/index.d.cts",
    "check": "bun run typecheck && bun run test",
    "test": "bun run test:unit && bun run test:e2e",
    "test:unit": "bun test --timeout 180000 tests/session.test.ts tests/exec.test.ts",
    "test:e2e": "bun test --timeout 180000 tests/e2e/cases",
    "test:coverage": "bun test --timeout 180000 --coverage tests/session.test.ts tests/exec.test.ts",
    "typecheck": "tsc --noEmit",
    "verify": "bun run clean && bun run build && bun run check",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "2.1.100",
    "claude-code-parser": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "terser": "^5.46.1",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT"
}
