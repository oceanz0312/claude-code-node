{
  "name": "claude-code-node",
  "version": "0.0.2",
  "description": "TypeScript SDK for Claude Code CLI",
  "repository": {
    "type": "git",
    "url": "https://github.com/oceanz0312/claude-code-node"
  },
  "keywords": [
    "claude-code",
    "claude",
    "agent-sdk",
    "cli-wrapper",
    "anthropic",
    "typescript",
    "streaming",
    "session-management"
  ],
  "author": "",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run clean && bun run build:esm && bun run build:cjs && bun run build:types && bun run build:cjs-dts",
    "build:esm": "bun build ./src/index.ts --outdir ./dist --target node --format esm --packages external",
    "build:cjs": "bun build ./src/index.ts --outfile ./dist/index.cjs --target node --format cjs --packages external",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "build:cjs-dts": "printf 'export * from \"./index.js\";\\n' > dist/index.d.cts",
    "check": "bun run typecheck && bun run test:unit && bun run test:e2e",
    "test:unit": "bun test tests/unit",
    "test:e2e": "bun test --timeout 180000 tests/e2e/cases",
    "test:coverage": "bun test --coverage tests/unit",
    "typecheck": "tsc --noEmit",
    "verify": "bun run clean && bun run build && bun run check",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "2.1.100",
    "claude-code-parser": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "terser": "^5.46.1",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT"
}
