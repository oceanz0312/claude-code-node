{
  "name": "@tiktok-fe/ttls-agent-sdk",
  "version": "0.1.3-alpha.1",
  "description": "TypeScript SDK for Claude Code CLI",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun run build:esm && bun run build:cjs && bun run build:types && bun run build:cjs-dts",
    "build:esm": "bun build ./src/index.ts --outdir ./dist --target node --format esm --packages external",
    "build:cjs": "bun build ./src/index.ts --outfile ./dist/index.cjs --target node --format cjs",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "build:cjs-dts": "printf 'export * from \"./index.js\";\\n' > dist/index.d.cts",
    "check": "bun run typecheck && bun test",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "verify": "bun run clean && bun run build && bun run check",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "claude-code-parser": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
