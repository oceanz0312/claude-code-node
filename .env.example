# E2E Test Configuration
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# Then load before running tests:
#   source .env && bun run test:e2e

# Optional: defaults to "sonnet" when omitted
export E2E_MODEL=sonnet

# Fill this to enable the api-key auth path
export E2E_API_KEY=

# Fill these to enable the auth-token auth path
export E2E_AUTH_TOKEN=
export E2E_BASE_URL=
